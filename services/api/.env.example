# ---- Application ----
APP_NAME=ai-bos-api
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/v1
VERSION=0.1.0

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://aibos:aibos@localhost:5432/aibos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false
DATABASE_STATEMENT_TIMEOUT_MS=30000

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ---- CORS (comma-separated) ----
CORS_ORIGINS=http://localhost:3000
